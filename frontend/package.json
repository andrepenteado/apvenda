{
  "name": "venda",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "_comment_overrides": "ngx-toastr@20.0.5 ainda declara peer @angular ^21.0.0; remover este override quando o ngx-toastr lançar suporte ao Angular 22",
  "overrides": {
    "ngx-toastr": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core"
    }
  },
  "dependencies": {
    "@andre.penteado/ngx-apcore": "^22.0.0",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@bugsplat/ngx-animated-counter": "^18.0.0",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@grafana/faro-web-sdk": "^2.8.2",
    "@grafana/faro-web-tracing": "^2.8.2",
    "@ng-select/ng-select": "^23.2.0",
    "bootstrap": "^5.3.8",
    "bootswatch": "^5.3.8",
    "chart.js": "^4.5.1",
    "datatables.net": "^2.3.6",
    "datatables.net-bs5": "^2.3.6",
    "datatables.net-buttons": "^3.2.6",
    "datatables.net-buttons-bs5": "^3.2.6",
    "datatables.net-buttons-dt": "^3.2.6",
    "datatables.net-colreorder": "^2.1.2",
    "datatables.net-colreorder-bs5": "^2.1.2",
    "datatables.net-colreorder-dt": "^2.1.2",
    "datatables.net-responsive": "^3.0.7",
    "datatables.net-responsive-bs5": "^3.0.7",
    "datatables.net-responsive-dt": "^3.0.7",
    "jquery": "^4.0.0",
    "jszip": "^3.10.1",
    "ngx-mask": "^22.0.0",
    "ngx-toastr": "^20.0.0",
    "ngx-ui-loader": "^19.0.0",
    "pdfmake": "^0.3.2",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.17",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@types/jquery": "^4.0.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}

<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2026-02-07" author="André Penteado">
        <comment>Tabela upload da lib br.unesp.fc.andrepenteado.core:upload (mapeada pela lib, criada aqui pois a lib nao traz o changelog). Precede o produto por causa da FK fk_produto_foto.</comment>
        <createTable tableName="upload">
            <column name="uuid" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_upload"/>
            </column>
            <column name="nome" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="descricao" type="VARCHAR"/>
            <column name="tipo_mime" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="tamanho" type="BIGINT"/>
            <column name="base64" type="TEXT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="marca">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_marca"/>
            </column>
            <column name="nome" type="VARCHAR">
                <constraints nullable="false" unique="true" uniqueConstraintName="un_marca_nome"/>
            </column>
            <column name="criado_por" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="criado_em" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="alterado_por" type="VARCHAR"/>
            <column name="alterado_em" type="TIMESTAMP"/>
        </createTable>
        <createIndex tableName="marca" indexName="idx_marca_nome">
            <column name="nome"/>
        </createIndex>

        <createTable tableName="categoria">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_categoria"/>
            </column>
            <column name="nome" type="VARCHAR">
                <constraints nullable="false" unique="true" uniqueConstraintName="un_categoria_nome"/>
            </column>
            <column name="ativo" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="fk_categoria_pai" type="BIGINT"/>
            <column name="criado_por" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="criado_em" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="alterado_por" type="VARCHAR"/>
            <column name="alterado_em" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="categoria"
            baseColumnNames="fk_categoria_pai"
            constraintName="fk_categoria_categoria_pai"
            referencedTableName="categoria"
            referencedColumnNames="id"/>
        <createIndex tableName="categoria" indexName="idx_categoria_nome">
            <column name="nome"/>
        </createIndex>
        <createIndex tableName="categoria" indexName="idx_categoria_categoria_pai">
            <column name="fk_categoria_pai"/>
        </createIndex>

        <createTable tableName="produto">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_produto"/>
            </column>
            <column name="nome" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="codigo_barras" type="VARCHAR"/>
            <column name="fk_categoria" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="fk_marca" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="unidade" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="preco_venda" type="NUMERIC"/>
            <column name="custo_compra" type="NUMERIC"/>
            <column name="estoque_atual" type="NUMERIC"/>
            <column name="ativo" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="fk_foto" type="UUID"/>
            <column name="observacao" type="TEXT"/>
            <column name="criado_por" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="criado_em" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="alterado_por" type="VARCHAR"/>
            <column name="alterado_em" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="produto"
            baseColumnNames="fk_categoria"
            constraintName="fk_produto_categoria"
            referencedTableName="categoria"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="produto"
            baseColumnNames="fk_marca"
            constraintName="fk_produto_marca"
            referencedTableName="marca"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="produto"
            baseColumnNames="fk_foto"
            constraintName="fk_produto_foto"
            referencedTableName="upload"
            referencedColumnNames="uuid"/>
        <createIndex tableName="produto" indexName="idx_produto_nome">
            <column name="nome"/>
        </createIndex>
        <createIndex tableName="produto" indexName="idx_produto_codigo_barras">
            <column name="codigo_barras"/>
        </createIndex>
        <createIndex tableName="produto" indexName="idx_produto_categoria">
            <column name="fk_categoria"/>
        </createIndex>
        <createIndex tableName="produto" indexName="idx_produto_marca">
            <column name="fk_marca"/>
        </createIndex>

        <createTable tableName="venda">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_venda"/>
            </column>
            <column name="data_hora" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="total" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
            <column name="criado_por" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="criado_em" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="alterado_por" type="VARCHAR"/>
            <column name="alterado_em" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="item_venda">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_item_venda"/>
            </column>
            <column name="fk_venda" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="fk_produto" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="quantidade" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
            <column name="valor_unitario" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
            <column name="valor_total" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="receber">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_receber"/>
            </column>
            <column name="fk_venda" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="parcela" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="data_vencimento" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="data_pagamento" type="DATE"/>
            <column name="forma_pagamento" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="valor_a_receber" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
            <column name="valor_pago" type="NUMERIC"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="item_venda"
            baseColumnNames="fk_venda"
            constraintName="fk_item_venda_venda"
            referencedTableName="venda"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="item_venda"
            baseColumnNames="fk_produto"
            constraintName="fk_item_venda_produto"
            referencedTableName="produto"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="receber"
            baseColumnNames="fk_venda"
            constraintName="fk_receber_venda"
            referencedTableName="venda"
            referencedColumnNames="id"/>
        <createIndex tableName="item_venda" indexName="idx_item_venda_venda">
            <column name="fk_venda"/>
        </createIndex>
        <createIndex tableName="item_venda" indexName="idx_item_venda_produto">
            <column name="fk_produto"/>
        </createIndex>
        <createIndex tableName="receber" indexName="idx_receber_venda">
            <column name="fk_venda"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
